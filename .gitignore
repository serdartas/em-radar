# Git ignore for generated and local-only files

# macOS
.DS_Store

# GitHub backlog helper
/docs/backlog/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.python-version
venv/
.venv/
env/
.env

# Node / frontend
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
pnpm-debug.log.*
package-lock.json
pnpm-lock.yaml
# build output
/dist/
build/

# IDE/editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swm
*.tmp
*~
*.bak

# Logs and runtime
*.log
*.sqlite3
*.sqlite
*.db

# Temporary files
*.tmp
*.temp

# Coverage and reports
coverage/
htmlcov/

# Other
*.DS_Store
